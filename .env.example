# ── Core ────────────────────────────────────────────────────────────────────
ENV=development
APP_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database & Cache ─────────────────────────────────────────────────────────
# Plain postgresql:// — the app computes +asyncpg, Alembic computes +psycopg2
DATABASE_URL=postgresql://traderogon:traderogon@localhost:5432/traderogon
REDIS_URL=redis://localhost:6379

# ── Market data (Databento) ──────────────────────────────────────────────────
DATABENTO_API_KEY=
# Continuous-contract symbols tracked by the engine
DATABENTO_NQ_SYMBOL=NQ.c.0
DATABENTO_ES_SYMBOL=ES.c.0
DATABENTO_DATASET=GLBX.MDP3

# ── Observability ────────────────────────────────────────────────────────────
SENTRY_DSN=
